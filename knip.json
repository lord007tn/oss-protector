{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/actions/**/*.ts",
    "src/functions/**/*.ts",
    "src/**/*.test.ts",
    "src/router.tsx",
    "src/routes/**/*.tsx",
    "src/server.ts"
  ],
  "project": ["*.ts", "src/**/*.{ts,tsx}"],
  "ignoreFiles": [
    "src/components/ui/chart.tsx",
    "src/components/ui/scroll-area.tsx",
    "src/components/ui/skeleton.tsx",
    "src/components/ui/switch.tsx"
  ],
  "ignoreIssues": {
    "src/auth.ts": ["exports"],
    "src/components/landing/analytics.ts": ["exports"],
    "src/components/landing/constants.ts": ["exports"],
    "src/components/landing/directory-lists.tsx": ["exports"],
    "src/components/landing/shared.tsx": ["exports"],
    "src/components/oss/signal-bars.tsx": ["exports"],
    "src/components/ui/**": ["exports", "types"],
    "src/data-access/directory.ts": ["exports", "types"],
    "src/data-access/maintainer-dashboard.ts": ["types"],
    "src/data-access/repo-decisions.ts": ["exports"],
    "src/db/index.ts": ["exports", "types"],
    "src/env.ts": ["exports", "types"],
    "src/helpers/directory-filters.ts": ["exports", "types"],
    "src/helpers/repository-policy.ts": ["exports", "types"],
    "src/hooks/api/dashboard/use-dashboard.ts": ["exports", "types"],
    "src/generated/github-stars.ts": ["exports"],
    "src/lib/appeals.ts": ["exports"],
    "src/lib/json.ts": ["exports", "types"],
    "src/lib/oss.ts": ["exports", "types"],
    "src/lib/pr-signals.ts": ["exports"],
    "src/lib/secret-crypto.ts": ["exports"],
    "src/lib/time.ts": ["exports", "types"]
  },
  "ignoreBinaries": ["changelogithub"],
  "ignoreDependencies": [
    "@fontsource-variable/geist",
    "@fontsource-variable/geist-mono",
    "@octokit/webhooks",
    "@tailwindcss/typography",
    "@tanstack/react-router-ssr-query",
    "@tanstack/router-plugin",
    "@testing-library/dom",
    "@testing-library/react",
    "commitizen",
    "jose",
    "recharts",
    "shadcn",
    "tailwindcss",
    "tw-animate-css"
  ]
}
