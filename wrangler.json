    "OPENROUTER_MODEL": "qwen/qwen3-next-80b-a3b-instruct:free",
    "OPENROUTER_FALLBACK_MODELS": "openai/gpt-oss-120b:free,deepseek/deepseek-v4-flash:free,z-ai/glm-4.7-flash,openai/gpt-5-nano"
  },
  "d1_databases": [
    {
      "binding": "clankers_db",
