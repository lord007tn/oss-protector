{
  "name": "oss-protector",
  "account_id": "REDACTED_CF_ACCOUNT_ID",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2026-05-14",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  },
  "vars": {
    "APP_NAME": "OSS Protector",
    "VITE_APP_URL": "https://oss-protector.raedbahri90.workers.dev",
    "CLOUDFLARE_D1_DATABASE_NAME": "clankers-list-db",
    "GITHUB_APP_SLUG": "oss-protector",
    "VITE_GITHUB_APP_SLUG": "oss-protector"
  },
  "d1_databases": [
    {
      "binding": "clankers_db",
      "database_name": "clankers-list-db",
      "database_id": "REDACTED_D1_DATABASE_ID",
      "migrations_dir": "drizzle"
    }
  ],
  "ratelimits": [
    {
      "name": "PUBLIC_RL",
      "namespace_id": "1001",
      "simple": { "limit": 60, "period": 60 }
    }
  ]
}
