VITE_APP_URL=http://localhost:3000
VITE_ENABLE_GITHUB_AUTH=true
VITE_ENABLE_EMAIL_OTP=true
VITE_ENABLE_DEVTOOLS=false
ALLOW_UNSIGNED_GITHUB_WEBHOOKS=false
# Required for any sign-in. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Email OTP delivery. Without RESEND_API_KEY the code is logged to the server
# console (fine for local dev). EMAIL_FROM needs a Resend-verified domain in prod.
RESEND_API_KEY=
EMAIL_FROM=OSS Protector <onboarding@resend.dev>

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
CLOUDFLARE_D1_DATABASE_NAME=oss-protector

GITHUB_APP_ID=
GITHUB_APP_SLUG=oss-protector
VITE_GITHUB_APP_SLUG=oss-protector
GITHUB_APP_PRIVATE_KEY=
GITHUB_MANIFEST_TOKEN=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_CREATE_OWNER=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

OPENROUTER_API_KEY=
SMOKE_HEALTH_TOKEN=
VITE_GITHUB_REPO_SLUG=lord007tn/oss-protector
VITE_GITHUB_STARS=
